msgid "Aragats Antar — восстанавливаем леса Армении для будущих поколений."
msgstr "Aragats Antar — վերականգնում ենք Հայաստանի անտառները հանուն ապագա սերունդների:"

#: .\main\views.py:114 .\main\views.py:326 .\main\views.py:635
msgid "Главная"
msgstr "Գլխավոր"

#: .\main\views.py:114 .\main\views.py:327 .\main\views.py:635
